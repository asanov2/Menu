# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=qrmenu
POSTGRES_PASSWORD=secret
POSTGRES_DB=qrmenu
DATABASE_URL=postgresql+asyncpg://qrmenu:secret@postgres:5432/qrmenu

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# MinIO (S3-compatible object storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=qrmenu-images
MINIO_USE_SSL=false

# =============================================================================
# RabbitMQ
# =============================================================================
RABBITMQ_USER=qrmenu
RABBITMQ_PASSWORD=secret
RABBITMQ_URL=amqp://qrmenu:secret@rabbitmq:5672/

# =============================================================================
# Frontend URLs
# =============================================================================
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174
OWNER_FRONTEND_URL=http://localhost:5175
MENU_FRONTEND_URL=http://localhost:5173

# =============================================================================
# Internal service URLs
# =============================================================================
AUTH_SERVICE_URL=http://auth-service:8002
MENU_SERVICE_URL=http://menu-service:8001
ADMIN_SERVICE_URL=http://admin-service:8003
BILLING_SERVICE_URL=http://billing-service:8004
ANALYTICS_SERVICE_URL=http://analytics-service:8005
OWNER_SERVICE_URL=http://owner-service:8006

# =============================================================================
# Kaspi Pay
# =============================================================================
KASPI_PAY_MERCHANT_ID=your-merchant-id
KASPI_PAY_API_KEY=your-kaspi-api-key
KASPI_PAY_API_URL=https://api.kaspi.kz/pay/v1
KASPI_PAY_CALLBACK_URL=http://localhost/api/billing/kaspi/callback

# =============================================================================
# CloudPayments
# =============================================================================
CLOUDPAYMENTS_PUBLIC_ID=your-public-id
CLOUDPAYMENTS_API_SECRET=your-api-secret
CLOUDPAYMENTS_API_URL=https://api.cloudpayments.ru
CLOUDPAYMENTS_CALLBACK_URL=http://localhost/api/billing/cloudpayments/callback

# =============================================================================
# Telegram (notifications bot)
# =============================================================================
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# =============================================================================
# Misc
# =============================================================================
DEBUG=false
ENVIRONMENT=development
