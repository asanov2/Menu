# === FILE: services/billing/.env.example ===

# PostgreSQL — same instance as other services, schemas separated
DATABASE_URL=postgresql+asyncpg://qrmenu:secret@postgres:5432/qrmenu

# Internal service communication
AUTH_SERVICE_URL=http://auth-service:8002
INTERNAL_SECRET=change-me-to-a-strong-random-secret

# Webhook signature secrets (fill in after getting credentials from providers)
KASPI_WEBHOOK_SECRET=kaspi-webhook-secret
CLOUDPAYMENTS_WEBHOOK_SECRET=cloudpayments-webhook-secret

# Trial length in days
TRIAL_DAYS=14

# App settings
DEBUG=false
PORT=8005
